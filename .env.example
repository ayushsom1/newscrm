# ---- backend ----
DATABASE_URL=postgresql+psycopg://crm:crm@db:5432/crm
SECRET_KEY=change-me-in-prod
# OpenRouter (OpenAI-compatible). Swap models via env, no code change.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
# OPENROUTER_FALLBACK_MODELS=anthropic/claude-3-haiku,openai/gpt-4o-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_HTTP_REFERER=https://news-crm.local
OPENROUTER_APP_TITLE=News CRM

# Operational
LOG_LEVEL=INFO            # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=text           # text (dev) | json (prod)
DISABLE_SCHEDULER=        # set 1 to skip APScheduler (tests/dev)
CORS_ORIGINS=http://localhost:3001
RESEND_API_KEY=

# ---- db ----
POSTGRES_USER=crm
POSTGRES_PASSWORD=crm
POSTGRES_DB=crm

# ---- frontend ----
VITE_API_URL=http://localhost:8001
